{
  "expo": {
    "name": "Your Block",
    "slug": "your-block",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.theblock.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D14"
      },
      "package": "com.theblock.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "The Block",
      "shortName": "The Block",
      "description": "your private photo neighborhood",
      "backgroundColor": "#08080F",
      "themeColor": "#08080F",
      "lang": "en",
      "display": "standalone"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "The Block needs camera access to share real moments."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "The Block uses location to add context to your memories."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#9B8FFF"
        }
      ],
      "expo-font"
    ],
    "scheme": "theblock",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c3d3611c-c930-408e-a537-5be1a833a9f8"
      }
    }
  }
}
